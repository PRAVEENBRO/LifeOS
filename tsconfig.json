{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "rootDir": "src",
    "outDir": "dist",

    "strict": true,
    "noImplicitAny": true,

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    "moduleResolution": "node",
    "resolveJsonModule": true,

    "sourceMap": true,
    "incremental": true,

    "skipLibCheck": true,
    "types": ["node"]
  },
"include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
